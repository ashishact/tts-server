# WebSocket server base URL (no trailing slash)
WS_URL=wss://api.ramble.my

# Conversation / room to join  (maps to the Durable Object instance)
CONVERSATION_ID=tts-server

# Identity for this agent on the server
USER_ID=tts-server

# Auth token (optional — omit for local/unauthenticated dev)
# TOKEN=your_jwt_here

# Kokoro model files  (download from HuggingFace hexgrad/Kokoro-82M)
MODEL_PATH=checkpoints/kokoro-v1.0.onnx
VOICES_PATH=data/voices-v1.0.bin

# Voice name  (run with RUST_LOG=debug to list available voices)
VOICE=af_heart

# Language code passed to the G2P phonemizer
LANGUAGE=en-us

# Speech speed  (1.0 = normal)
SPEED=1.0

# Number of parallel synthesis workers.
# Each worker loads one copy of the model (~310 MB RAM each).
# 2 = two users synthesised simultaneously, others queue.
TTS_WORKERS=2
